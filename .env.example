# ---------------------------------------------------------------------------
# Facility Thermostat Dashboard - example configuration.
# Copy this file to .env and fill it in:   cp .env.example .env
# Never commit your real .env (it holds secrets); .gitignore already excludes it.
# ---------------------------------------------------------------------------

# --- Honeywell / Resideo credentials (REQUIRED) ---
# Get these from https://developer.honeywellhome.com -> My Apps.
# These are placeholders - replace with your OWN key/secret.
HONEYWELL_API_KEY=your-consumer-key-here
HONEYWELL_API_SECRET=your-consumer-secret-here

# Must be BYTE-FOR-BYTE identical to the Redirect URI registered on the portal.
# The port here (8010) must match the port this app runs on (see PORT below).
HONEYWELL_REDIRECT_URI=http://localhost:8010/auth/callback

# --- Polling ---
# The Basic developer plan is sized for ~20 devices every 5 minutes. Don't drop
# below 300 unless Resideo has granted you a higher rate limit.
POLL_INTERVAL_SECONDS=300

# --- Rate limiter guardrails (client-side safety net) ---
RL_MIN_INTERVAL=1.0
RL_HOURLY_CAP=250

# --- MQTT (optional) ---
# Set MQTT_ENABLED=true to publish thermostat state and accept commands/triggers.
# Defaults match the local Mosquitto broker used by the mqtt-dev project.
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_BASE_TOPIC=honeywell

# --- Scheduler ---
# IANA timezone for time-of-day schedules, e.g. America/New_York.
# Leave blank to use the server's local timezone.
SCHEDULE_TZ=

# --- Sole Controller mode ---
# When true (the default and intended mode), the app continuously holds every
# zone under a permanent hold so the thermostats' onboard schedules and the
# Resideo app never drive them - this app is the single top controller. This is
# only the STARTUP default; you can toggle it live from the dashboard and that
# choice is remembered. Set to false to let zones follow their onboard schedules.
SOLE_CONTROLLER=true

# --- Server ---
# Default port is 8010 so this can coexist with GenWatch (which uses 8000) on
# the same host. If you change it, update HONEYWELL_REDIRECT_URI to match.
HOST=0.0.0.0
PORT=8010

# --- Optional dashboard access gate ---
# If set, the dashboard and API require ?token=... or an X-Token header.
# This is a light guard, NOT real authentication - put the app behind a VPN or
# an authenticating reverse proxy for anything exposed beyond a trusted LAN.
DASHBOARD_TOKEN=
