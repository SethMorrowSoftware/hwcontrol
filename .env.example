# ---------------------------------------------------------------------------
# Facility Thermostat Dashboard - example configuration.
# Copy this file to .env and fill it in:   cp .env.example .env
# Never commit your real .env (it holds secrets); .gitignore already excludes it.
# ---------------------------------------------------------------------------

# --- Honeywell / Resideo credentials (REQUIRED) ---
# Get these from https://developer.honeywellhome.com -> My Apps.
# These are placeholders - replace with your OWN key/secret.
HONEYWELL_API_KEY=your-consumer-key-here
HONEYWELL_API_SECRET=your-consumer-secret-here

# Must be BYTE-FOR-BYTE identical to the Redirect URI registered on the portal.
# The port here (8010) must match the port this app runs on (see PORT below).
HONEYWELL_REDIRECT_URI=http://localhost:8010/auth/callback

# --- Polling ---
# The Basic developer plan is sized for ~20 devices every 5 minutes. Don't drop
# below 300 unless Resideo has granted you a higher rate limit.
POLL_INTERVAL_SECONDS=300

# --- Rate limiter guardrails (client-side safety net) ---
RL_MIN_INTERVAL=1.0
RL_HOURLY_CAP=250
# Retry transient failures so a control action eventually lands instead of failing
# on a blip. Covers 429 (honoring the server's Retry-After), 5xx, and network
# errors, for reads AND writes (writes are idempotent). Retries go through the
# rate limiter. RL_MAX_RETRIES=0 disables; RL_RETRY_MAX_SLEEP caps any single wait
# (seconds) so a bad Retry-After can't park a worker for an hour.
RL_MAX_RETRIES=4
RL_RETRY_MAX_SLEEP=120

# --- MQTT (optional) ---
# Set MQTT_ENABLED=true to publish thermostat state and accept commands/triggers.
# Defaults match the local Mosquitto broker used by the mqtt-dev project.
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_BASE_TOPIC=honeywell

# --- Slack alerts (optional) ---
# Post a Slack message when a unit goes offline, and again when it comes back
# online (one message per transition - no repeats while it stays down). Uses a
# Slack *bot* token (starts with "xoxb-") calling chat.postMessage.
#   1. Create a Slack app (https://api.slack.com/apps) -> "OAuth & Permissions"
#      -> add the "chat:write" Bot Token Scope -> "Install to Workspace" ->
#      copy the "Bot User OAuth Token" (xoxb-...).
#   2. Invite that bot into the channel you want alerts in: /invite @your-app
#   3. Set SLACK_CHANNEL to the channel's ID (e.g. C0123456789, found via the
#      channel's "View channel details") or a #channel-name.
# Both a token AND a channel are required; leave SLACK_ENABLED=false to disable.
# These are just the STARTUP defaults: you can also set all three live from the
# dashboard (Alerts tab -> Slack notifications), and that saved choice — token
# included — then wins over these values and persists across restarts.
SLACK_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_CHANNEL=

# --- Scheduler ---
# IANA timezone your schedule times are written in. STRONGLY RECOMMENDED to set
# this: if left blank the app uses the SERVER's local timezone, and most servers
# run in UTC - so "22:00 Off" would fire at 22:00 UTC (6pm Eastern in summer),
# i.e. hours off. Use a full IANA name like America/New_York (NOT a bare "EST" -
# America/New_York handles the EST/EDT daylight-saving switch for you).
SCHEDULE_TZ=America/New_York

# --- Sole Controller mode ---
# When true (the default and intended mode), the app continuously holds every
# zone under a permanent hold so the thermostats' onboard schedules and the
# Resideo app never drive them - this app is the single top controller. This is
# only the STARTUP default; you can toggle it live from the dashboard and that
# choice is remembered. Set to false to let zones follow their onboard schedules.
SOLE_CONTROLLER=true

# --- Schedule enforcement ---
# When true, every update re-checks each program-covered zone against what its
# schedule says right now and corrects any that drifted (someone changed the temp
# at the thermostat or in the Resideo app). It's drift-aware, so a zone already on
# its program costs no API calls. Off by default; toggle it live on the dashboard's
# main page (the choice is remembered). Distinct from SOLE_CONTROLLER: that holds a
# zone at its current values; this forces the PROGRAM's values back.
SCHEDULE_ENFORCE=false

# --- Server ---
# Default port is 8010 so this can coexist with GenWatch (which uses 8000) on
# the same host. If you change it, update HONEYWELL_REDIRECT_URI to match.
HOST=0.0.0.0
PORT=8010

# --- Optional dashboard access gate ---
# If set, the dashboard and API require ?token=... or an X-Token header.
# This is a light guard, NOT real authentication - put the app behind a VPN or
# an authenticating reverse proxy for anything exposed beyond a trusted LAN.
DASHBOARD_TOKEN=
